/**
 * 「成长小树苗」全局样式 — Design Token
 * 来源：design-spec-成长小树苗.md §2.1-2.3
 */

page {
  /* === 颜色 Token === */
  --green: #5CB85C;
  --green-light: #E8F5E9;
  --green-dark: #4CA84C;
  --yellow: #F0AD4E;
  --yellow-light: #FFF8E1;
  --blue: #5BC0DE;
  --blue-light: #E3F4FA;
  --bg: #FFF8F0;
  --card-bg: #FFFFFF;
  --text: #333333;
  --text-secondary: #888888;
  --text-light: #AAAAAA;
  --border: #E8E0D8;
  --orange-tag: #FFF3E0;
  --orange-text: #F0AD4E;
  --danger: #E57373;
  --danger-light: #FFEBEE;
  --gold: #F4B400;

  /* === 字号（rpx，1rpx = 0.5px @375 基准）=== */
  --fs-xs: 22rpx;
  --fs-sm: 24rpx;
  --fs-base: 28rpx;
  --fs-md: 32rpx;
  --fs-lg: 36rpx;
  --fs-xl: 44rpx;
  --fs-2xl: 56rpx;

  /* === 间距 === */
  --sp-xs: 8rpx;
  --sp-sm: 12rpx;
  --sp-md: 16rpx;
  --sp-lg: 24rpx;
  --sp-xl: 32rpx;
  --sp-2xl: 48rpx;

  /* === 圆角 === */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;

  /* === 阴影 === */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);

  /* === 安全区 === */
  --safe-top: 88rpx;    /* statusBar + navBar = 44px + 44px */
  --safe-bottom: env(safe-area-inset-bottom, 0);

  /* === 全局应用 === */
  background-color: var(--bg);
  color: var(--text);
  font-size: var(--fs-base);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
               "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  box-sizing: border-box;
}

/* 全局 reset */
view, text, image, scroll-view, swiper, swiper-item {
  box-sizing: border-box;
}

/* 单行省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 多行省略 */
.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 安全区域底部 padding */
.safe-bottom {
  padding-bottom: var(--safe-bottom);
}
