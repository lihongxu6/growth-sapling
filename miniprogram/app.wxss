/**
 * 「成长小树苗」全局样式 — Design Token
 * 来源：design-spec-成长小树苗.md §2.1-2.3
 */

page {
  /* === 全局应用 === */
  background-color: #FFF8F0;
  color: #333333;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
               "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  box-sizing: border-box;

  /* === 颜色 Token === */
  --green: #5CB85C;
  --green-light: #E8F5E9;
  --green-dark: #4CA84C;
  --yellow: #F0AD4E;
  --yellow-light: #FFF8E1;
  --blue: #5BC0DE;
  --blue-light: #E3F4FA;
  --bg: #FFF8F0;
  --card-bg: #FFFFFF;
  --text: #333333;
  --text-secondary: #888888;
  --text-light: #AAAAAA;
  --border: #E8E0D8;
  --orange-tag: #FFF3E0;
  --orange-text: #F0AD4E;
  --danger: #E57373;
  --danger-light: #FFEBEE;
  --gold: #F4B400;

  /* === 字号（rpx，1rpx = 0.5px @375 基准）=== */
  --fs-xs: 24rpx;
  --fs-sm: 26rpx;
  --fs-base: 28rpx;
  --fs-md: 32rpx;
  --fs-lg: 36rpx;
  --fs-xl: 44rpx;
  --fs-2xl: 56rpx;

  /* === 间距 === */
  --sp-xs: 8rpx;
  --sp-sm: 12rpx;
  --sp-md: 16rpx;
  --sp-lg: 24rpx;
  --sp-xl: 32rpx;
  --sp-2xl: 48rpx;

  /* === 圆角（对齐 design-spec §2.4）=== */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 999rpx;

  /* === 阴影 === */
  --shadow-card: 0 2rpx 6rpx rgba(0,0,0,0.05);
  --shadow-float: 0 16rpx 48rpx rgba(0,0,0,0.12);

  /* === 安全区 === */
  --safe-top: 88rpx;
  --safe-bottom: env(safe-area-inset-bottom, 0);
}

/* 全局 reset */
view, text, image, scroll-view, swiper, swiper-item {
  box-sizing: border-box;
}

/* 单行省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 多行省略 */
.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 安全区域底部 padding */
.safe-bottom {
  padding-bottom: var(--safe-bottom);
}
