/* 开屏页 v2.0 样式 — 对齐 ui-mockup-v2-splash.html（已锁版） */
.splash {
  position: fixed;
  inset: 0;
  background-color: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  /* 状态栏安全区：顶部/底部留白，不显示品牌名/假时间/信号/电量（design-spec §3.1） */
  padding-top: env(safe-area-inset-top, 0);
  padding-bottom: env(safe-area-inset-bottom, 0);
  /* 淡出过渡：停留 1.5s 后 opacity→0（600ms），再 switchTab */
  opacity: 1;
  transition: opacity 0.6s ease;
  z-index: 9999;
}

/* 淡出态：透明度归零并禁止点击穿透 */
.splash.fading {
  opacity: 0;
  pointer-events: none;
}

.splash-logo {
  font-size: 144rpx; /* 72px @375 基准 */
  line-height: 1;
  animation: splashPop 0.6s ease both;
}

.splash-name {
  font-size: 56rpx; /* 28px */
  font-weight: 800;
  color: var(--green);
  letter-spacing: 2rpx;
  line-height: 1.2;
  animation: splashPop 0.6s ease 0.15s both;
}

.splash-slogan {
  font-size: 26rpx; /* 13px，--fs-caption */
  color: var(--text-secondary);
  line-height: 1.4;
  animation: splashPop 0.6s ease 0.25s both;
}

/* 入场动画：0.6 缩放淡入（与高保真稿同曲线） */
@keyframes splashPop {
  from { transform: scale(0.6); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}
