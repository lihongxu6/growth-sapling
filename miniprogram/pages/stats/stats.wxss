/* 统计页样式 */
@import '../../app.wxss';

.page {
  min-height: 100vh;
  padding-bottom: var(--safe-bottom);
}

.status-bar {
  width: 100%;
  background: var(--bg);
}

/* === 连续天数 === */
.streak-section {
  display: flex;
  gap: var(--sp-md);
  padding: var(--sp-lg);
}

.streak-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  padding: var(--sp-lg);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.streak-icon {
  font-size: var(--fs-2xl);
}

.streak-info {
  display: flex;
  flex-direction: column;
}

.streak-num {
  font-size: var(--fs-lg);
  font-weight: 700;
  color: var(--text);
}

.streak-label {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

/* === 区块 === */
.section {
  padding: 0 var(--sp-lg);
  margin-bottom: var(--sp-xl);
}

.section-title {
  font-size: var(--fs-md);
  font-weight: 600;
  margin-bottom: var(--sp-md);
  display: block;
}

/* === 日历 === */
.cal-grid {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: var(--sp-md);
  box-shadow: var(--shadow-sm);
}

.cal-weekdays {
  display: flex;
  margin-bottom: var(--sp-sm);
}

.cal-weekday {
  flex: 1;
  text-align: center;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

.cal-days {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cal-day {
  font-size: var(--fs-sm);
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
}

.cal-cell.green .cal-day {
  background: var(--green-light);
  color: var(--green);
  font-weight: 600;
}

.cal-cell.orange .cal-day {
  background: var(--yellow-light);
  color: var(--yellow);
  font-weight: 600;
}

.cal-cell.today .cal-day {
  border: 2rpx solid var(--green);
}

/* === 徽章墙 === */
.badge-wall {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-sm);
}

.badge-card {
  width: calc(50% - 6rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--sp-lg) var(--sp-sm);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  position: relative;
}

.badge-card.locked {
  opacity: 0.5;
}

.badge-card.acquired {
  border: 2rpx solid var(--gold);
}

.badge-icon {
  font-size: var(--fs-2xl);
  margin-bottom: var(--sp-xs);
}

.badge-name {
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text);
}

.badge-desc {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.badge-lock {
  position: absolute;
  top: var(--sp-sm);
  right: var(--sp-sm);
  font-size: var(--fs-sm);
}

/* === 空状态 === */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--sp-2xl);
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--sp-lg);
}

.empty-title {
  font-size: var(--fs-md);
  color: var(--text);
  margin-bottom: var(--sp-sm);
}

.empty-desc {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  text-align: center;
}
