/* 统计页样式 */
@import '../../app.wxss';

.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: var(--safe-bottom);
}

/* === 用户信息区（v2.0 本地版） === */
.user-card {
  margin: 0 var(--sp-lg);
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: var(--sp-lg);
  position: relative;
}
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
}
.avatar-circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid var(--green);
  overflow: hidden;
  background: var(--green-light);
  box-sizing: border-box;
}
/* 图片为圆的直接子元素：填满 + aspectFill 居中裁剪，定位完全可控 */
.avatar {
  width: 100%;
  height: 100%;
  display: block;
}
/* 透明覆盖层：仅用于触发 chooseAvatar，不参与图片渲染，避免布局干扰居中 */
/* 关键：尺寸必须显式 112rpx，绝不能用 width:100% —— 绝对定位下 % 在真机会解析到视口(750rpx)，
   导致覆盖层铺满整张卡片、盖住右侧昵称输入框（#52 踩坑） */
.avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 112rpx;
  height: 112rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  border: none;
  opacity: 0;
  z-index: 2;
}
.avatar-btn::after {
  border: none;
}
.avatar-badge {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--green);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--bg);
  z-index: 3;
  pointer-events: none;
}
.user-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}
.user-name {
  font-size: var(--fs-card-title);
  font-weight: 700;
  color: var(--text);
  width: 100%;
  background: transparent;
  border: none;
}

/* === 连续天数 === */
.streak-section {
  display: flex;
  gap: var(--sp-md);
  padding: var(--sp-lg);
}

.streak-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  padding: var(--sp-lg);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.streak-icon {
  font-size: var(--fs-2xl);
}

.streak-info {
  display: flex;
  flex-direction: column;
}

.streak-num {
  font-size: var(--fs-lg);
  font-weight: 700;
  color: var(--text);
}

.streak-label {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

/* === 区块 === */
.section {
  padding: 0 var(--sp-lg);
  margin-bottom: var(--sp-xl);
}

.section-title {
  font-size: var(--fs-md);
  font-weight: 600;
  margin-bottom: var(--sp-md);
  display: block;
}

/* === 本周完成率环图 === */
.ring-wrap {
  display: flex;
  align-items: center;
  gap: var(--sp-lg);
  padding: var(--sp-md);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--sp-md);
}

.ring {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ring-inner {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--green);
}

.ring-desc {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  flex: 1;
}

/* === 日历 === */
.cal-month {
  font-size: var(--fs-aux);
  font-weight: 700;
  color: var(--text-secondary);
  margin-bottom: var(--sp-sm);
  display: block;
}

.cal-grid {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: var(--sp-md);
  box-shadow: var(--shadow-sm);
}

.cal-weekdays {
  display: flex;
  margin-bottom: var(--sp-sm);
}

.cal-weekday {
  flex: 1;
  text-align: center;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

.cal-days {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cal-day {
  font-size: var(--fs-sm);
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
}

.cal-cell.green .cal-day {
  background: var(--green-light);
  color: var(--green);
  font-weight: 600;
}

.cal-cell.orange .cal-day {
  background: var(--yellow-light);
  color: var(--yellow);
  font-weight: 600;
}

.cal-cell.today .cal-day {
  border: 2rpx solid var(--green);
}

.cal-cell.disabled {
  opacity: 0.35;
  pointer-events: none;
}

/* === 徽章墙（对齐设计稿：grayscale + text-shadow） === */
.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-md);
}

.badge {
  width: calc(50% - var(--sp-md) / 2);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  text-align: center;
  padding: var(--sp-lg) var(--sp-sm);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
  position: relative;
}

.badge-icon {
  font-size: 60rpx;
  filter: grayscale(1);
  opacity: 0.5;
}

.badge.earned .badge-icon {
  filter: none;
  opacity: 1;
  text-shadow: 0 0 8px rgba(244, 180, 0, 0.5);
}

.badge-name {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.badge.earned .badge-name {
  color: var(--text);
}

.badge-prog {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.badge.locked .badge-icon {
  position: relative;
}

.badge-reserved {
  opacity: 0.4;
}

/* === 空状态 === */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--sp-2xl);
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--sp-lg);
}

.empty-title {
  font-size: var(--fs-md);
  color: var(--text);
  margin-bottom: var(--sp-sm);
}

.empty-desc {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  text-align: center;
}
