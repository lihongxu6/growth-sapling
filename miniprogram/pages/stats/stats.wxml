<!-- 统计页 -->
<view class="page">

  <!-- 用户信息区（顶部，v2.0 本地版） -->
  <view class="user-card">
    <view class="avatar-wrap">
      <!-- 头像即 chooseAvatar 按钮本身：普通 flex 子元素，被布局限制在 112rpx 头像列内，物理上不可能外溢盖住昵称（#52 去覆盖层）-->
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar" src="{{avatarUrl || defaultAvatar}}" mode="aspectFill" />
      </button>
      <view class="avatar-badge">✎</view>
    </view>
    <view class="user-meta">
      <input class="user-name" type="nickname" value="{{nickname}}" bindblur="onNicknameBlur" bindconfirm="onNicknameConfirm" />
      <!-- 昵称右侧编辑图标：独立 tap 目标，引导用户点右侧改名字（#52 产品方案兜底）-->
      <view class="name-edit" bindtap="onEditNameTap">✎</view>
    </view>
  </view>

  <!-- 连续天数展示 -->
  <view class="streak-section">
    <view class="streak-card">
      <text class="streak-icon">🔥</text>
      <view class="streak-info">
        <text class="streak-num">{{streak}} 天</text>
        <text class="streak-label">连续打卡</text>
      </view>
    </view>
    <view class="streak-card">
      <text class="streak-icon">⭐</text>
      <view class="streak-info">
        <text class="streak-num">{{stars}}</text>
        <text class="streak-label">累计星星</text>
      </view>
    </view>
  </view>

  <!-- 本周完成率 -->
  <view class="section">
    <text class="section-title">本周完成率</text>
    <view class="ring-wrap">
      <view class="ring" style="background: conic-gradient(var(--green) 0% {{weekRate}}%, #EFE7DC {{weekRate}}% 100%);">
        <view class="ring-inner">{{weekRate}}%</view>
      </view>
      <text class="ring-desc">这一周你完成得很棒，继续保持！</text>
    </view>
  </view>

  <!-- 本月概览 -->
  <view class="section">
    <text class="section-title">打卡日历</text>
    <text class="cal-month">{{calYear}}年 {{calMonth}}月</text>
    <view class="cal-grid">
      <view class="cal-weekdays">
        <text wx:for="{{weekDays}}" wx:key="*this" class="cal-weekday">{{item}}</text>
      </view>
      <view class="cal-days">
        <view
          wx:for="{{calDays}}"
          wx:key="index"
          class="cal-cell {{item.color}} {{item.isToday ? 'today' : ''}} {{item.disabled ? 'disabled' : ''}}"
          data-day="{{item.day}}"
          data-iso="{{item.iso}}"
          bindtap="onPickDate"
        >
          <text class="cal-day">{{item.day}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 徽章墙 -->
  <view class="section">
    <text class="section-title">🏅 徽章墙</text>
    <view class="badge-grid">
      <view
        wx:for="{{badges}}"
        wx:key="type"
        class="badge {{item.acquired ? 'earned' : 'locked'}}"
      >
        <text class="badge-icon">{{item.icon}}</text>
        <text class="badge-name">{{item.name}}</text>
        <text class="badge-prog">{{item.prog}}</text>
      </view>
      <!-- 保留位 -->
      <view class="badge locked badge-reserved">
        <text class="badge-icon">🔒</text>
        <text class="badge-name">敬请期待</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{stars <= 7}}">
    <image class="empty-image" src="/miniprogram-assets/avatar.png" mode="aspectFit"></image>
    <text class="empty-title">还没有成长记录哦</text>
    <text class="empty-desc">坚持打卡，你的成长数据和小树苗都会在这里！</text>
  </view>
</view>
